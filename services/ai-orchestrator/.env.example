# Java callback target
JAVA_API_BASE_URL=http://localhost:8080
INTERNAL_SERVICE_TOKEN=internal-dev-token-change-in-production

# Text LLM: product analysis, plans, script, storyboard, prompt/quality JSON.
# Put the real key in services/ai-orchestrator/.env, not in git.
TEXT_LLM_PROVIDER=openai_compatible
TEXT_LLM_MODEL=doubao-seed-2-1-pro-260628
TEXT_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
TEXT_LLM_API_KEY=
FORCE_FAKE_LLM=false

# Keep expensive media generation disabled by default.
ENABLE_IMAGE_GENERATION=false
IMAGE_GEN_PROVIDER=openai
MAX_IMAGE_ASSETS_PER_TASK=4 

ENABLE_VIDEO_GENERATION=false
VIDEO_GEN_PROVIDER=openai
MAX_VIDEO_CLIPS_PER_TASK=0
VIDEO_GEN_REQUIRE_APPROVAL=true

# Per-task cost guard. Video generation should require an explicit higher cap.
AI_COST_LIMIT_PER_TASK=2.0
