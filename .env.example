# ============================================================
# TK AI Video System — Root Environment Variables
# Copy to .env and fill in production values.
# ============================================================

# JWT
JWT_SECRET=change-me-to-a-random-256-bit-key
INTERNAL_SERVICE_TOKEN=change-me-internal-token

# Database
POSTGRES_DB=tk_ai_video
POSTGRES_USER=tk_user
POSTGRES_PASSWORD=tk_dev_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_URL=amqp://tk_user:tk_dev_password@localhost:5672

# AI Providers
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
IMAGE_GEN_PROVIDER=openai
VIDEO_GEN_PROVIDER=openai

# Cost limits (per task in USD)
AI_COST_LIMIT_PER_TASK=5.0

# ============================================================
# 腾讯云 COS (对象存储)
# 所有素材、AI 生成图片/视频、最终成片统一存储到这里
# ============================================================
COS_SECRET_ID=           # 在 腾讯云控制台 → 访问管理 → API密钥 获取
COS_SECRET_KEY=          # 同上
COS_REGION=ap-guangzhou  # 例如 ap-guangzhou, ap-shanghai, ap-singapore
COS_BUCKET=              # 格式: your-bucket-name-1234567890 (含 APPID)
COS_CDN_DOMAIN=          # (可选) 绑定 CDN 加速域名，留空使用默认 COS 域名

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default

# Service URLs
JAVA_API_BASE_URL=http://localhost:8080
AI_ORCHESTRATOR_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8080
