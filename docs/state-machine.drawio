        <mxCell id="e-vcg-wvcc" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;" parent="1" source="video_clip_generating" target="waiting_video_clip_confirmation" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- waiting_video_clip_confirmation → rendering -->
        <mxCell id="e-wvcc-rend" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;" parent="1" source="waiting_video_clip_confirmation" target="rendering" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== EDGES: V1 chain (vertical, right side) ==================== -->

        <mxCell id="e-anz-ac" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;" parent="1" source="analyzing" target="analysis_completed" edge="1">
          <mxGeometry relative="1" as="geometry" />
