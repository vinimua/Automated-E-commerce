          <mxGeometry x="50" y="1630" as="geometry" />
        </mxCell>

        <!-- repairing → keyframe_configuring -->
        <mxCell id="e-rep-kfc" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#EA6B66;dashed=1;exitX=1;exitY=0.25;" parent="1" source="repairing" target="keyframe_configuring" edge="1">
          <mxGeometry relative="1" as="geometry" />
