          <mxGeometry x="200" y="1700" as="geometry" />
        </mxCell>

        <!-- repairing → image_generating -->
        <mxCell id="e-rep-img" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#EA6B66;dashed=1;exitX=0;exitY=0.25;" parent="1" source="repairing" target="image_generating" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- repairing → video_clip_generating -->
        <mxCell id="e-rep-vcg" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#EA6B66;dashed=1;exitX=1;exitY=0.5;" parent="1" source="repairing" target="video_clip_generating" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- repairing → rendering -->
        <mxCell id="e-rep-rend" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#EA6B66;dashed=1;exitX=0;exitY=0.75;" parent="1" source="repairing" target="rendering" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== EDGES: Failed → retry ==================== -->
        <mxCell id="e-fail-anz" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#999999;dashed=1;dashPattern=2 4;fontSize=8;exitX=0;exitY=0.25;" parent="1" source="failed" target="analyzing" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-fail-scg" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#999999;dashed=1;dashPattern=2 4;fontSize=8;exitX=0;exitY=0.5;" parent="1" source="failed" target="script_generating" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== EDGES: Any → cancelled / failed ==================== -->
        <mxCell id="cancel-note" value="任意非终态节点 可随时 → cancelled&lt;br&gt;（终态: completed / exported / failed / cancelled）" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;rounded=1;" parent="1" vertex="1">
          <mxGeometry x="1140" y="1280" width="300" height="40" as="geometry" />
