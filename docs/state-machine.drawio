        <mxCell id="e-ac-pg" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;" parent="1" source="analysis_completed" target="plan_generated" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- plan_generated → waiting_plan_selection already defined above (e-pg-wps) -->

        <mxCell id="e-scg-scgd" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;" parent="1" source="script_generating" target="script_generated" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-scgd-mtg" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;" parent="1" source="script_generated" target="material_generating" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-mtg-mtd" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;" parent="1" source="material_generating" target="material_generated" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- material_generated → rendering -->
        <mxCell id="e-mtd-rend" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;exitX=0;exitY=0.5;" parent="1" source="material_generated" target="rendering" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== EDGES: Rendering → end states ==================== -->

        <!-- rendering → checking (V1) -->
        <mxCell id="e-rend-chk" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;exitX=1;exitY=0.5;" parent="1" source="rendering" target="checking" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- rendering → waiting_final_review (Fashion) -->
        <mxCell id="e-rend-wfr" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;exitX=0;exitY=0.5;" parent="1" source="rendering" target="waiting_final_review" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- checking → completed -->
        <mxCell id="e-chk-cmp" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;" parent="1" source="checking" target="completed" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- waiting_final_review → completed -->
        <mxCell id="e-wfr-cmp" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;" parent="1" source="waiting_final_review" target="completed" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- completed → exported -->
        <mxCell id="e-cmp-exp" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;fontSize=9;" parent="1" source="completed" target="exported" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== EDGES: Repair loop ==================== -->
        <!-- waiting_final_review → repairing -->
        <mxCell id="e-wfr-rep" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#EA6B66;dashed=1;exitX=0;exitY=1;" parent="1" source="waiting_final_review" target="repairing" edge="1">
          <mxGeometry relative="1" as="geometry" />
